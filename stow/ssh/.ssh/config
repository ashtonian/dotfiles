# SSH Configuration Template
# This file is managed by dotfiles - host-specific configs should go in ~/.ssh/config.local

# Default settings for all hosts
Host *
    AddKeysToAgent yes
    IgnoreUnknown UseKeychain
    UseKeychain yes
    IdentityFile ~/.ssh/id_ed25519
    StrictHostKeyChecking accept-new
    IdentitiesOnly yes
    HashKnownHosts yes
    ControlMaster auto
    ControlPath ~/.ssh/control-%C
    ControlPersist 600

# Include local/machine-specific SSH config
Include config.local
